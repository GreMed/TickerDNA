# TickerDNA 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# SEC EDGAR API User Agent（用于美股公司数据获取）
# 格式：Your Name your.email@example.com
SEC_USER_AGENT=

# OpenAI API Key（可选，用于智能研究报告生成）
OPENAI_API_KEY=

# 公司搜索 Provider 顺序（可选，默认 local,eastmoney_a_share,cninfo,sec,yahoo）
# COMPANY_SEARCH_PROVIDERS=local,eastmoney_a_share,cninfo,sec,yahoo
